{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/generate.py": {
      "runtime": "python3.12"
    }
  },
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
